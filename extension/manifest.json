{
  "manifest_version": 3,
  "name": "Shift Extension - Eco LLM",
  "version": "1.0",
  "description": "Track the environmental impact of your LLM prompts.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://api.ecologits.ai/*",
    "https://*.upstash.io/*",
    "https://shift-jade.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
