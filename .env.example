# Shift Environment Variables
# Copy this file to .env.local and fill in your actual values

# LLM APIs (required)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Climatiq API (required)
CLIMATIQ_API_KEY=your_climatiq_api_key_here

# Electricity Maps API (required)
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# Google Maps Platform (required)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Upstash Redis (required)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Upstash Vector (for Eco LLM semantic cache)
UPSTASH_VECTOR_URL=https://your-vector.upstash.io
UPSTASH_VECTOR_TOKEN=your_upstash_vector_token_here

# PostHog Analytics 
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
